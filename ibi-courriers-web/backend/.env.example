DATABASE_URL=postgresql://ibi:ibi_secret@db:5432/ibi_courriers
SECRET_KEY=changez-moi-en-production-avec-une-cle-longue
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOAD_DIR=/data/uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# En production : ENVIRONMENT=production, SECRET_KEY unique (32+ caractères),
# DATABASE_URL sans mot de passe par défaut « ibi_secret ».

# Notifications e-mail (optionnel)
SMTP_ENABLED=false
SMTP_HOST=smtp.mail.ovh.net
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=courriers@ibi.ci
BACKUP_DIR=/data/backups
MIGRATION_DIR=/data/migration
OCR_ENABLED=true